{
  "name": "onevibe",
  "private": true,
  "version": "0.1.0",
  "description": "Open-source governed AI workspace with a Manus-like task UX and ONEComputer security controls.",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c green,cyan \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch server/index.ts",
    "dev:web": "vite",
    "build": "tsc -b && tsc -p tsconfig.server.json && vite build",
    "check": "npm run lint && npm run test && npm run build",
    "lint": "oxlint src server",
    "test": "vitest run",
    "preview": "vite preview"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.210",
    "fflate": "^0.8.3",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "oxlint": "^1.71.0",
    "tsx": "^4.23.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
